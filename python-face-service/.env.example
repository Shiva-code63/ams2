# Where embeddings are stored (default: ./uploads/faces)
FACE_SERVICE_UPLOAD_DIR=

# Warm up ArcFace / RetinaFace on startup (default: true)
FACE_SERVICE_WARMUP=true

# Enable extra debug payload + logs (default: false)
FACE_SERVICE_DEBUG=false

# Liveness checks (OpenCV heuristic; default: false)
FACE_SERVICE_ENABLE_LIVENESS=false

# Image quality gating
FACE_SERVICE_MIN_BRIGHTNESS=55.0
FACE_SERVICE_MIN_BLUR_VAR=80.0

# Cosine similarity match threshold (default: 0.5)
FACE_SERVICE_SIMILARITY_THRESHOLD=0.5

# Frame limits (verification)
FACE_SERVICE_MAX_VERIFY_FRAMES=12
FACE_SERVICE_MAX_REGISTER_IMAGES=5

# Log directory (default: ./logs)
FACE_SERVICE_LOG_DIR=
